# サバゲー進行システム 環境設定
# このファイルを .env にコピーして使用してください

# サーバーポート番号
PORT=3000

# UNIT-C6L (Meshtastic) USB シリアルポート
# Windows: COM3, COM4 など
# Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0 など
SERIAL_PORT=COM3

# LoRa 送信ノード -> ポジション (JSON, 任意)
# 例: {"!f115c414":"A","!abc12345":"B"}
# LORA_NODE_MAP={}

# 本文が BUTTON_ON detected のときのデフォルトポジション
LORA_DEFAULT_POSITION=A

# 短押し/長押しの判定ウィンドウ (ms)
# 1回目のパルス受信後、この時間内に2回目が届けば「長押し」、届かなければ「短押し」
# ESP32側はパルスを約3秒間隔で2回送るため、4500ms程度を推奨
LORA_LONG_PRESS_WINDOW_MS=4500

# 実行環境
# development: 開発モード（Meshtastic通信なし、ブラウザのデバッグ信号のみで動作確認）
# production: 本番モード（Meshtastic通信あり）
NODE_ENV=development
